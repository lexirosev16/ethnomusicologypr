        },
        {
          "text": "La esperanza se crece "
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "La ceremonio en tu mente"
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "De que se cuero endurece "
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Se defenderá la inocencia"
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Se defendera la paciencia "
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Hay un misterio en su ausencia "
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Se puede mirada conciencia "
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "... se creciente"
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Su (rona) la tierra que entiende"
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Es en mi alma enciende"
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "La vida creciende"
        }
      ],
