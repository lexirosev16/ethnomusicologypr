{"annotations":[{"start_time":0,"end_time":356,"annotation":[{"text":"\"Esa, esa Dominé\" Don Rafael Cepeda Atiles","bold":true},{"type":"line-break","children":[{"text":""}]},{"text":"Coro","bold":true},{"type":"line-break","children":[{"text":""}]},{"text":"Esa, esa Dominé"},{"type":"line-break","children":[{"text":""}]},{"text":"Esa, esa Dominé"},{"type":"line-break","children":[{"text":""}]},{"text":"Esa, esa Dominé"},{"type":"line-break","children":[{"text":""}]},{"text":"Mi Salvatore de viva mue"},{"type":"line-break","children":[{"text":""}]},{"text":"Versos","bold":true},{"type":"line-break","children":[{"text":""}]},{"text":"Eso dile a Valentin "},{"type":"line-break","children":[{"text":""}]},{"text":"Lo que le dice Manuel "},{"type":"line-break","children":[{"text":""}]},{"text":"Que no vaya pa la bomba si no bailaba Paulé"},{"type":"line-break","children":[{"text":""}]},{"text":"Ay yo vi ayer Urubina "},{"type":"line-break","children":[{"text":""}]},{"text":"Me dijo que quiere usted "},{"type":"line-break","children":[{"text":""}]},{"text":"Que le prenda una vela debe prender al revés "},{"type":"line-break","children":[{"text":""}]},{"text":"Ya los zumban a la vez por el rio de Portugues "},{"type":"line-break","children":[{"text":""}]},{"text":"Lleva un hechizo en la mano "},{"type":"line-break","children":[{"text":""}]},{"text":"Pa conquistar a José"},{"type":"line-break","children":[{"text":""}]},{"text":"Esa, esa Dominé"},{"type":"line-break","children":[{"text":""}]},{"text":"Esa, esa Shangoté"},{"type":"line-break","children":[{"text":""}]},{"text":"Esa, esa viva mué"},{"type":"line-break","children":[{"text":""}]},{"text":"Mi salvatore de Shangoté"}],"tags":[{"category":"Speaker","tag":"Don Rafael Cepeda Atiles"},{"category":"Genre","tag":"bomba"}],"uuid":"de0cdeb7-6fab-4a20-bcd6-76a7969f8cda"},{"start_time":357,"end_time":462,"annotation":[{"text":"\"Son más divina\" Don Rafael Cepeda Atiles","bold":true},{"type":"line-break","children":[{"text":""}]},{"text":"Coro ","bold":true},{"type":"line-break","children":[{"text":""}]},{"text":"Son, son más divina "},{"type":"line-break","children":[{"text":""}]},{"text":"Versos","bold":true},{"text":"\nMás divina son balancé\nMás divina son (yo son Laré)\nMás divina son balancé"}],"tags":[{"category":"Speaker","tag":"Don Rafael Cepeda Atiles"},{"category":"Genre","tag":"bomba"},{"category":"Genre","tag":"sicá"}],"uuid":"566b15ca-d6b3-443b-9420-838a89e57e07"},{"start_time":474,"end_time":953,"annotation":[{"text":"\"Petronila Guilbe\" Don Rafael Cepeda Atiles","bold":true},{"type":"line-break","children":[{"text":""}]},{"text":"Coro","bold":true},{"type":"line-break","children":[{"text":""}]},{"text":"Petronila Guilbe, yo no declaré"},{"type":"line-break","children":[{"text":""}]},{"text":"Versos","bold":true},{"type":"line-break","children":[{"text":""}]},{"text":"Ay que, yo no declaré que yo no declaré"},{"type":"line-break","children":[{"text":""}]},{"text":"Ay, preguntale al cura preguntaleso al juez"},{"type":"line-break","children":[{"text":""}]},{"text":"Ay, que suenen los tambores que tocaba Manuel"},{"type":"line-break","children":[{"text":""}]},{"text":"Ay que Petronila Guilbe que yo no declaré"},{"type":"line-break","children":[{"text":""}]},{"text":"Ay, cantando dulce bomba me voy pa' Mayaguez"}],"tags":[{"category":"Speaker","tag":"Don Rafael Cepeda Atiles"},{"category":"Genre","tag":"bomba"},{"category":"Genre","tag":"sicá"}],"uuid":"0ec21d2b-908f-4bb9-acfc-eb5c53e006d9"},{"start_time":995,"end_time":1020,"annotation":[{"type":"paragraph","children":[{"text":"La música de Cangrejos en el río es una de esas tradiciones que conocen bien en las fincas, donde alumbran las huevas y preparan los sacos para recoger la pesca. Muy bien realizada por la familia Cepeda. ¡Continuemos con La Borucana!"}]}],"tags":[{"category":"Speaker","tag":"Luis Palo Matos"},{"category":"Theme","tag":"cultural heritage"}],"uuid":"0bdc316b-3d97-4108-9a7b-de7db22c1610"},{"start_tim